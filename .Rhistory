rider_id <- sub(".*/rider/([^/?]+).*", "\\1", href)  # slug (bv. "eddy-merckx")
name <- a %>% html_text() %>% str_squish()
tibble(name = name, rider_id = rider_id)
})
res
# compact, betrouwbaar: PCS all-time (offset=0) -> name, rider_id, points
library(rvest); library(httr); library(dplyr); library(purrr); library(stringr); library(readr)
url <- "https://www.procyclingstats.com/rankings.php?p=all-time&s=&nation=&age=&page=smallerorequal&team=&offset=0&active=&filter=Filter"
ua  <- httr::user_agent("r-pcs-scraper/1.0 (+https://your.email.example)")
page <- read_html(GET(url, ua))
rows <- page %>% html_element(".basic") %>% html_element("tbody") %>% html_nodes("tr")
res <- map_df(rows, function(r) {
a <- r %>% html_node("a[href*='rider/']")
href <- a %>% html_attr("href")
rider_id <- sub(".*rider/([^/?]+).*", "\\1", href)  # slug (bv. "eddy-merckx")
name <- a %>% html_text() %>% str_squish()
tibble(name = name, rider_id = rider_id)
})
res
# compact, betrouwbaar: PCS all-time (offset=0) -> name, rider_id, points
library(rvest); library(httr); library(dplyr); library(purrr); library(stringr); library(readr)
url <- "https://www.procyclingstats.com/rankings.php?p=all-time&s=&nation=&age=&page=smallerorequal&team=&offset=0&active=&filter=Filter"
ua  <- httr::user_agent("r-pcs-scraper/1.0 (+https://your.email.example)")
page <- read_html(GET(url, ua))
rows <- page %>% html_element(".basic") %>% html_element("tbody") %>% html_nodes("tr")
res <- map_df(rows, function(r) {
a <- r %>% html_node("a[href*='rider/']")
href <- a %>% html_attr("href")
rider_id <- sub(".*rider/([^/?]+).*", "\\1", href)  # slug (bv. "eddy-merckx")
name <- a %>% html_text() %>% str_squish()
tds  <- r %>% html_nodes("td") %>% html_text() %>% str_squish()
points <- if (length(tds) > 0) readr::parse_number(tail(tds, 1)) else NA_real_
tibble(name = name, rider_id = rider_id, points = points)
})
res

rider_id <- res$rider_id[1]
df <- map_df(res$rider_id, function(i) {
url <- glue::glue("https://www.procyclingstats.com/rider/{i}/results/all-time-ranking")
page <- read_html(url)
tables <- page %>%  html_elements(".mt50")
# XPath: kies div waarvan een directe child <h4> bevat 'age' (case-insensitive)
# predicate: div[h4 and contains( translate(normalize-space(h4),...),'age' )]
divs <- page %>% html_nodes(xpath =
"//div[h4 and contains(translate(normalize-space(h4), 'ABCDEFGHIJKLMNOPQRSTUVWXYZ','abcdefghijklmnopqrstuvwxyz'), 'age')]"
)
message("Aantal divs met direct child <h4> die 'age' bevat: ", length(divs))
if (length(divs) == 0) stop("Geen directe div gevonden met een child <h4> die 'age' bevat.")
# neem de eerste match (of loop over divs om meerdere secties te pakken)
divs[[1]] %>%
html_element(".basic") %>% html_table() %>% as_tibble() %>% mutate(rider_id = i) %>%
select(rider_id, age = Age, points = Points, total_points = Cumulative)
})
df

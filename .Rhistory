pic_metadata
files <- list.files(path = "data", pattern = ".JPEG", recursive = TRUE, full.names = T)
one_file <- files[1]
# Toon ALLE metadata-velden
all_tags <- read_exif(one_file)
names(all_tags)
pic_metadata <- read_exif(files, tags = c("filename", "DateTimeOriginal", "GPSLongitude","GPSLatitude","GPSTimeStamp","GPSImgDirection"))
pic_metadata
